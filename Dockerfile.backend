# ==========================================
# 1. ETAP: DEPENDENCIES (Wspólny dla dev i prod)
# ==========================================
FROM node:22-slim AS deps
WORKDIR /app

# Ustawiamy globalny store pnpm, aby współpracował z naszymi wolumenami
ENV PNPM_HOME="/pnpm-store"
ENV PATH="$PNPM_HOME:$PATH"

RUN corepack enable

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY frontend/package.json ./frontend/package.json
COPY backend/package.json ./backend/package.json

RUN pnpm install --frozen-lockfile

# ==========================================
# 2. ETAP: DEVELOPMENT
# ==========================================
FROM deps AS dev
WORKDIR /app/backend
EXPOSE 3001
CMD ["pnpm", "start:dev"]

# ==========================================
# 3. ETAP: BUILD (Tylko do produkcji)
# ==========================================
FROM deps AS build
WORKDIR /app
COPY backend ./backend
WORKDIR /app/backend
RUN pnpm build

# ==========================================
# 4. ETAP: DEPLOY (Przygotowanie odchudzonego buildu)
# ==========================================
FROM deps AS deploy
WORKDIR /app
COPY backend ./backend
RUN pnpm --filter backend --prod deploy --legacy /prod/backend

# ==========================================
# 5. ETAP: PRODUCTION (Finalny, lekki obraz)
# ==========================================
FROM node:22-slim AS prod
WORKDIR /app
RUN corepack enable
# Kopiujemy tylko to, co wygenerował etap deploy (bez pnpm-store i devDependencies!)
COPY --from=deploy /prod/backend ./
COPY --from=build /app/backend/dist ./dist
EXPOSE 3000
CMD ["pnpm", "start:prod"]
